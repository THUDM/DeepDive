# DeepDive training paths
DEEPDIVE_ROOT=/path/to/DeepDive
SLIME_ROOT=${DEEPDIVE_ROOT}/training/slime

# Tool server
TOOL_SERVER_PORT=7230
SEARCH_PROVIDER=serper
SERPER_API_KEY=your_serper_key
SERP_API_KEY=your_serpapi_key
JINA_API_KEY=your_jina_key
HTTP_PROXY=

# Reward server, OpenAI-compatible
RM_TRAIN_PORT=8888
REWARD_MODEL_NAME=gpt-4o-mini
REWARD_BASE_URL=https://api.openai.com/v1
REWARD_API_KEY=sk-xxx

# Slime training
HF_MODEL_PATH=/path/to/hf/model
REF_MODEL_TORCH_DIST=/path/to/converted/torch_dist
PROMPT_DATA=/path/to/deepdive_rl_slime.jsonl
CKPT_DIR=/path/to/output/deepdive-rl
WANDB_API_KEY=

# DeepDive rollout strategy
DEEPDIVE_TOOL_SERVER_URL=http://127.0.0.1:7230/tool
DEEPDIVE_REWARD_SERVER_URL=http://127.0.0.1:8888/evaluate
DEEPDIVE_MAX_TURNS=64
DEEPDIVE_TOOL_MAX_RETRY=5
DEEPDIVE_TOOL_TIMEOUT=300
DEEPDIVE_STOP_ONCE_ILLFORM=1
DEEPDIVE_RETURN_LOGPROB=1
USE_DEEPDIVE_REWARD_FUNC=1
